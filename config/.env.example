# BotHelp skill — runtime config
# Заполняется автоматически мастером bothelp-oauth-setup.sh.
# Не коммить .env, только .env.example.

BOTHELP_ACCESS_TOKEN=
BOTHELP_TOKEN_TYPE=Bearer
# Epoch seconds, момент истечения токена.
# _common.sh сравнивает с now и обновляет за 60 сек до истечения.
BOTHELP_TOKEN_EXPIRES_AT=0

# Базовые URL (обычно не трогаем):
BOTHELP_API_BASE=https://api.bothelp.io
BOTHELP_OAUTH_BASE=https://oauth.bothelp.io
